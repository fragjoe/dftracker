{
  "name": "delta",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c green,blue \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start:api": "node server/index.js",
    "migrate:postgres": "node server/migrate-sqlite-to-postgres.js",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest --config vitest.config.js",
    "check": "npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "lucide": "^0.577.0",
    "postgres": "^3.4.8"
  }
}

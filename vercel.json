{
  "crons": [
    {
      "path": "/api/cron/refresh-leaderboard",
      "schedule": "0 */6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron/(.*)",
      "destination": "/api/cron/$1"
    },
    {
      "source": "/tracker-api/(.*)",
      "destination": "/api/tracker-api?path=$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://api.deltaforceapi.com/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

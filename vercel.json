{
    "rewrites": [
        {
            "source": "/tracker-api/(.*)",
            "destination": "/api/tracker-api/$1"
        },
        {
            "source": "/api/(.*)",
            "destination": "https://api.deltaforceapi.com/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
